# DevFolio Portfolio Template Configuration
# ==========================================

# ============================================
# OPTION A: Mock Data Mode (For Development)
# ============================================
# Use this to preview the template with sample data
# No API connection needed - perfect for development and customization
DEVFOLIO_USE_MOCK=true

# ============================================
# OPTION B: Live API Mode (For Production)
# ============================================
# Comment out DEVFOLIO_USE_MOCK above and configure one of these:

# Option B1: API Key (Recommended)
# Get your API key from: https://devfolio.com/dashboard/settings/api
# DEVFOLIO_API_KEY=your-api-key-here

# Option B2: User UUID (Public access only)
# Use this if you only need publicly visible data
# DEVFOLIO_USER_UUID=your-user-uuid-here

# API Base URL (usually don't need to change)
DEVFOLIO_API_URL=https://devfolio.com/api/v1

# ============================================
# Optional Configuration
# ============================================

# Your deployed site URL (for SEO and social sharing)
NEXT_PUBLIC_SITE_URL=https://yourportfolio.com

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
